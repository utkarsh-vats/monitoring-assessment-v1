# ==============================================================================
# Observable AI Backend Service - Environment Example Template (.env.example)
# ==============================================================================
# Copy this file to .env.local and populate your API keys for local development:
# cp .env.example .env.local

# ------------------------------------------------------------------------------
# Application Environment & Behavior
# ------------------------------------------------------------------------------
ENVIRONMENT=development

# Set to true ("1", "true", "yes") to force offline deterministic testing via Smart Mock Engine
FORCE_MOCK_MODE=false

# ------------------------------------------------------------------------------
# Multi-Provider LLM API Keys (Secrets)
# ------------------------------------------------------------------------------
# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------------------
# LLM Model Selection Defaults
# ------------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
